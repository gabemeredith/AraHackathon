# ---- Ara automation (app.py) ----
# These are read via ara.secret(...) in Ara's secret store, not from .env.
# Listed here for reference.
GATEWAY_URL=https://your-gateway.fly.dev
GATEWAY_KEY=replace-with-shared-secret
STORE_URL=https://your-upstash-url
STORE_TOKEN=replace-with-upstash-token

# ---- Twilio gateway (gateway/main.py) ----
TWILIO_SID=ACxxxxxxxx
TWILIO_TOKEN=xxxxxxxx
TWILIO_FROM=+1XXXXXXXXXX
GATEWAY_KEY=replace-with-shared-secret
STORE_URL=https://your-upstash-url
STORE_TOKEN=replace-with-upstash-token
